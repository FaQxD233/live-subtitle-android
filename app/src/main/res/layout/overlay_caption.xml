<?xml version="1.0" encoding="utf-8"?>
<!--
    Floating caption overlay.

    Root is a transparent FrameLayout. The inner `overlayRoot` LinearLayout is
    the visible "HUD" card. Four corner ImageViews (`overlayResizeTL/TR/BL/BR`)
    sit on top of the card so the user can resize from any corner — mirroring
    `hud_window.py:_TransparentSizeGrip` (4 QSizeGrips, one per corner).

    The whole `overlayRoot` is a drag handle; child buttons consume their own
    touches first, so dragging only fires when pressing empty card areas.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:id="@+id/overlayRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="20dp"
        android:background="@drawable/overlay_card_bg"
        android:elevation="16dp"
        android:outlineAmbientShadowColor="#66000000"
        android:outlineSpotShadowColor="#CC000000"
        android:minWidth="280dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Header: status dot + status text + lang badge + close btn -->
        <LinearLayout
            android:id="@+id/overlayHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/overlayStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/status_dot" />

            <TextView
                android:id="@+id/overlayStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/status_idle"
                android:textColor="#B4FFFFFF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/overlayLangBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/lang_badge_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="→"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- BILI direction swap button. Visibility is toggled in
                 CaptionOverlayView based on whether the active mode is
                 bidirectional. Hidden in LIVE mode. -->
            <Button
                android:id="@+id/overlayDirectionBtn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="28dp"
                android:padding="0dp"
                android:text="⇄"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/overlayCloseBtn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/overlay_btn_secondary"
                android:contentDescription="@string/overlay_close"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Translated output (primary, scrollable, fills remaining space) -->
        <ScrollView
            android:id="@+id/overlayOutputScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:scrollbarFadeDuration="0">

            <TextView
                android:id="@+id/overlayOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </ScrollView>

        <!-- Divider -->
        <View
            android:id="@+id/overlayDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#1AFFFFFF" />

        <!-- Original input (secondary, scrollable, fixed height) -->
        <ScrollView
            android:id="@+id/overlayInputScroll"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:fillViewport="true"
            android:scrollbars="vertical"
            android:scrollbarFadeDuration="0">

            <TextView
                android:id="@+id/overlayInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B4FFFFFF"
                android:textSize="12sp"
                android:textStyle="italic" />
        </ScrollView>

        <!-- Control bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/overlayToggleBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/overlay_btn_primary"
                android:minWidth="76dp"
                android:paddingHorizontal="12dp"
                android:text="@string/start"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/overlayClearBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_btn_secondary"
                android:minWidth="64dp"
                android:paddingHorizontal="12dp"
                android:text="@string/clear"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/overlaySettingsBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/overlay_btn_secondary"
                android:contentDescription="@string/open_settings"
                android:src="@android:drawable/ic_menu_preferences"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- Four corner resize handles. Each is 28dp × 28dp; the corner cursor
         hint comes from the drawable (resize_handle is rotation-agnostic,
         we visually flip it per corner via scaleX/scaleY in code if needed). -->
    <ImageView
        android:id="@+id/overlayResizeTL"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|start"
        android:contentDescription="@string/overlay_resize_top_left"
        android:padding="2dp"
        android:rotation="180"
        android:src="@drawable/resize_handle" />

    <ImageView
        android:id="@+id/overlayResizeTR"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:contentDescription="@string/overlay_resize_top_right"
        android:padding="2dp"
        android:rotation="90"
        android:src="@drawable/resize_handle" />

    <ImageView
        android:id="@+id/overlayResizeBL"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom|start"
        android:contentDescription="@string/overlay_resize_bottom_left"
        android:padding="2dp"
        android:rotation="-90"
        android:src="@drawable/resize_handle" />

    <ImageView
        android:id="@+id/overlayResizeBR"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="bottom|end"
        android:contentDescription="@string/overlay_resize_bottom_right"
        android:padding="2dp"
        android:src="@drawable/resize_handle" />
</FrameLayout>
